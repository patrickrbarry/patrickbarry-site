{
  "manifest_version": 3,
  "name": "Save to Patrick's Site",
  "version": "1.0",
  "description": "Save the current page as a recommended read.",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
